{
  "name": "lolicon.sx",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "pug src --out docs && node -e \"require('fs').copyFileSync('src/style.css','docs/style.css')\"",
    "watch:pug": "pug src --out docs --watch",
    "watch:serve": "browser-sync start --server docs --files \"docs/**/*\"",
    "dev": "npm run build && npm-run-all --parallel watch:*",
    "format": "prettier --write ./src"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oto-lab/lolicon.sx.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/oto-lab/lolicon.sx/issues"
  },
  "homepage": "https://github.com/oto-lab/lolicon.sx#readme",
  "devDependencies": {
    "@prettier/plugin-pug": "^3.4.2",
    "browser-sync": "^3.0.4",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.9.4",
    "pug": "^3.0.4",
    "pug-cli": "^1.0.0-alpha6"
  }
}
